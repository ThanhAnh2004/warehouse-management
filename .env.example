# ============================================================
#  WAREHOUSE MANAGEMENT SYSTEM - Biến môi trường mẫu
#  Copy file này thành `.env` (đã được .gitignore) và chỉnh sửa.
#  Các giá trị HOST dưới đây dùng cho môi trường Docker Compose
#  (host = tên service). Nếu chạy 1 service lẻ ngoài Docker,
#  đổi các *_HOST tương ứng thành localhost / 127.0.0.1.
# ============================================================

# --- API Gateway ---
API_GATEWAY_PORT=8000

# --- Identity & Auth Service ---
IDENTITY_SERVICE_HOST=identity-service
IDENTITY_SERVICE_PORT=8001
JWT_SECRET=change_this_super_secret_key
JWT_EXPIRES_IN=1h

# --- Inventory Service ---
INVENTORY_SERVICE_HOST=inventory-service
INVENTORY_SERVICE_PORT=8002

# --- Transaction Service ---
TRANSACTION_SERVICE_HOST=transaction-service
TRANSACTION_SERVICE_PORT=8003

# --- Notification / Alert Service ---
NOTIFICATION_SERVICE_HOST=notification-service
NOTIFICATION_SERVICE_PORT=3004

# --- Reporting & Analytics Service ---
REPORTING_SERVICE_HOST=reporting-service
REPORTING_SERVICE_PORT=3005

# --- Forecasting Service (Python) ---
FORECASTING_SERVICE_HOST=forecasting-service
FORECASTING_SERVICE_PORT=8004

# --- Data Processing Service (Python) --- [MỚI]
# Forecasting Service gọi service này để lấy dữ liệu đã làm sạch & chuẩn hóa.
# Trong Docker: host = tên service. Chạy lẻ ngoài Docker: đổi thành localhost.
DATA_PROCESSING_SERVICE_HOST=data-processing-service
DATA_PROCESSING_SERVICE_PORT=8005

# --- PostgreSQL (dùng chung cho Inventory & Transaction) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin123
POSTGRES_DB_INVENTORY=warehouse_inventory
POSTGRES_DB_TRANSACTION=warehouse_transactions

# --- MongoDB ---
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_URI_IDENTITY=mongodb://mongodb:27017/identity_db
MONGODB_URI_NOTIFICATION=mongodb://mongodb:27017/notification_db

# --- RabbitMQ (dùng cho System Health monitoring) ---
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
